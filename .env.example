RUNTIME_BACKEND=llama_cpp
LLAMA_HOST=127.0.0.1
LLAMA_PORT=8080
LLAMA_MODEL_ALIAS=brain
LLAMA_MODEL_PATH=models\brain.gguf
LLAMA_SERVER_BINARY=model-server\server.exe
LLAMA_CLI_BINARY=model-server\llama.exe
LLAMA_STARTUP_TIMEOUT=120
LLAMA_CHAT_TEMPLATE=brain
LLAMA_CHAT_TEMPLATE_FILE=prompts\brain-chat-template.jinja
LLAMA_CHAT_TEMPLATE_KWARGS={}
LLAMA_REASONING_BUDGET=0
LLAMA_REASONING_FORMAT=none
LLAMA_STOP_TOKENS=<|end|>,<|system|>,<|user|>,<|assistant|>
LLAMA_TOP_P=0.85
LLAMA_TOP_K=20
LLAMA_MIN_P=0
OLLAMA_NUM_PREDICT=256
OLLAMA_NUM_CTX=1024
OLLAMA_NUM_THREAD=2
OLLAMA_TEMPERATURE=0.1
REQUIRE_GPU=false
